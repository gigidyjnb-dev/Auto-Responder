node_modules/
.env
uploads/*
data/*.json
data/test-app.db
data/test-app.db-*
data/intent-test.db
data/intent-test.db-*
data/test-listing-parser.db
data/test-listing-parser.db-*
!data/.gitkeep
.aider*

# Explicitly include db.js (overrides global gitignore)
!src/db.js

# Extension build artifacts (generated) — re-assert after public/** include
public/extension/*.zip

# Experimental / unrelated sandbox (keep locally; do not ship with the app)
my-gemini-project/

# Global gitignore patterns like "public/" match on case-insensitive
# filesystems and would skip our web UI — force-track these paths.
!/public/
!/public/**

# Re-ignore extension zip after re-including public/**
public/extension/*.zip

