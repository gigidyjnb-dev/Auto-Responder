{
  "manifest_version": 3,
  "name": "Marketplace Auto-Responder",
  "description": "Sync listings and auto-reply to buyer messages on Facebook Marketplace and more.",
  "version": "2.0.0",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.ebay.com/*",
    "https://*.etsy.com/*",
    "https://*.offerup.com/*",
    "https://*.mercari.com/*",
    "https://*.poshmark.com/*",
    "https://*.craigslist.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/marketplace/inbox/*", "https://www.facebook.com/marketplace/item/*"],
      "js": ["content-inbox.js"],
      "run_at": "document_idle"
    }
  ]
}
