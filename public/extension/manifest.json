{
  "manifest": "v3",
  "name": "Marketplace Listing Sync",
  "description": "Automatically sync listings from marketplace platforms to your auto-responder",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.ebay.com/*",
    "https://*.etsy.com/*",
    "https://*.offerup.com/*",
    "https://*.mercari.com/*",
    "https://*.poshmark.com/*",
    "https://*.craigslist.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
