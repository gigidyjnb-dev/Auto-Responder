# Copy to `.env` for local dev. On Railway, set the same keys under Service → Variables.

PORT=3000

# --- Recommended for production (Railway) ---
# Strong login for /admin.html (8+ characters). Recommended on Railway.
ADMIN_PASSWORD=
# Set to true only if the process should refuse to start without ADMIN_PASSWORD (default: warn only)
FAIL_WITHOUT_ADMIN_PASSWORD=
# Recommended: stable secret so admin cookies survive restarts (or rely on INTEGRATION_API_KEY for signing)
ADMIN_SESSION_SECRET=

# Optional: OpenAI for smarter replies; if empty, the app uses FAQ/fallback copy only
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini

# Optional: required for /api/inbound, /api/outbound, /api/integrations/* (header x-integration-key)
INTEGRATION_API_KEY=replace-with-strong-shared-secret

# --- Facebook Messenger / Marketplace webhook (optional) ---
FB_PAGE_ACCESS_TOKEN=
FB_VERIFY_TOKEN=
FB_GRAPH_VERSION=v22.0

# --- Behaviour tuning ---
AUTO_SEND_ENABLED=true
AUTO_SEND_MIN_CONFIDENCE=0.72
OFFER_FLOOR_RATIO=0.75
SCAM_KEYWORDS=code,verification,zelle only,wire transfer,cashier check,ship to my cousin

ADMIN_SESSION_TTL_HOURS=12
ADMIN_LOGIN_RATE_WINDOW_MS=600000
ADMIN_LOGIN_RATE_MAX=20

INTEGRATION_RATE_WINDOW_MS=60000
INTEGRATION_RATE_MAX=180

# Optional: after admin approves a queued reply, POST JSON to this URL
OUTBOUND_BRIDGE_URL=
OUTBOUND_BRIDGE_KEY=
OUTBOUND_RETRY_ATTEMPTS=3
OUTBOUND_RETRY_DELAY_MS=250

# Optional: override SQLite path (default: data/app.db)
# Render persistent disk example: APP_DB_FILE=/var/data/app.db
# Railway volume example: APP_DB_FILE=/data/app.db
# APP_DB_FILE=

# Optional: comma-separated extra browser origins allowed to call the API in production
# Example: CORS_ALLOWED_ORIGINS=https://your-app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# --- Credential encryption (auto-import feature) ---
# Generate a 32-byte (64 hex chars) random key: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# CRED_ENCRYPTION_KEY= (required for production use of one-click import)
